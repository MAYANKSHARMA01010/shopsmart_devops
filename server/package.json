{
  "name": "shopsmart-server",
  "version": "1.0.0",
  "description": "Backend API for ShopSmart",
  "main": "src/server.ts",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "prisma generate && tsc",
    "test": "prisma generate && c8 --reporter=text --reporter=lcov --report-dir=coverage mocha -r ts-node/register 'tests/**/*.test.ts' --timeout 10000 --exit",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "zod": "^3.24.1",
    "express-rate-limit": "^8.4.1"
  },
  "devDependencies": {
    "@types/chai": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "c8": "^10.1.3",
    "chai": "^5.1.2",
    "eslint": "^10.3.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "globals": "^15.0.0",
    "mocha": "^11.1.0",
    "nodemon": "^3.1.14",
    "prisma": "6.2.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
