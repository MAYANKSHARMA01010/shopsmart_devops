# =====================================================
# ShopSmart — Local & CI Environment Template
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit real credentials.
# =====================================================

# --- AWS region (canonical name; mirrored to GitHub secret AWS_REGION) ---
AWS_REGION="us-east-1"

# Legacy alias, kept for older scripts (scripts/ec2*.sh expect REGION)
REGION="us-east-1"

# --- AWS Lab credentials (Copy-paste from AWS Details > CLI) ---
AWS_ACCESS_KEY_ID="your_access_key_id"
AWS_SECRET_ACCESS_KEY="your_secret_access_key"
AWS_SESSION_TOKEN="your_session_token"
AWS_ACCOUNT_ID="your_aws_account_id"

# --- Database (Postgres / Neon / RDS connection string) ---
DATABASE_URL="postgresql://user:password@host:5432/shopsmart"

# --- Docker Hub (only if mirroring images outside ECR) ---
DOCKERHUB_USERNAME=""
DOCKERHUB_PASSWORD=""

# --- EC2 host (used by scripts/ec2*.sh and 04-deploy if you keep that path) ---
INSTANCE_ID="your_instance_id_here"
TARGET_IP="your_public_ip_here"
KEY_NAME="vockey"
EC2_HOST=""
EC2_USER="ec2-user"
EC2_SSH_KEY=""
EC2_SECURITY_GROUP_ID=""
